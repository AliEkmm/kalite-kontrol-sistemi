# --- Eğitilmiş model dosyaları (büyük) ---
models/*
!models/.gitkeep

# --- Kullanıcı yüklemeleri ve üretilen sonuç görselleri ---
static/uploads/*
!static/uploads/.gitkeep
static/results/*
!static/results/.gitkeep

